[
  {
    "id": "TC001",
    "title": "Enable ZettAI via global AI switch shows success notification",
    "description": "Verifies that turning the global ZettAI switch ON succeeds and shows a visible success toast/message.",
    "category": "AI Global Switch (ZettAI toggle)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/main\""
      },
      {
        "type": "action",
        "description": "Navigate to /main/settings/ai-settings/ai-service"
      },
      {
        "type": "action",
        "description": "Click the AI (ZettAI) switch to turn it ON"
      },
      {
        "type": "assertion",
        "description": "Verify a success toast/notification text is visible"
      }
    ]
  },
