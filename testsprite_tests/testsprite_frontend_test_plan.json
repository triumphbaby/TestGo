  {
    "id": "TC005",
    "title": "Add a folder rule in 'Only Learn Specified Folders' mode and save successfully",
    "description": "Verifies a user can select 'Only Learn Specified Folders', add a folder via picker, and save with a success toast.",
    "category": "AI Learning Scope Settings",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to http://192.168.31.75/login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/main\""
      },
      {
        "type": "action",
        "description": "Navigate to http://192.168.31.75/main/settings/ai-settings/ai-service"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Learning Scope\" is visible"
      },
      {
        "type": "action",
        "description": "Select \"Only Learn Specified Folders\" from the Learning Scope dropdown"
      },
      {
        "type": "action",
        "description": "Click the \"+ Add\" button in the Learning Scope section"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Team Space\" is visible in the folder picker dialog"
      },
      {
        "type": "action",
        "description": "Click on \"Team Space\" in the folder picker dialog"
      },
      {
        "type": "assertion",
        "description": "Verify a directory tree is visible in the folder picker dialog"
      },
      {
        "type": "action",
        "description": "Click a visible folder name in the directory tree to select it"
      },
      {
        "type": "action",
        "description": "Click the \"Confirm\" button in the folder picker dialog"
      },
      {
        "type": "assertion",
        "description": "Verify the selected folder path is visible in the rule list"
      },
      {
        "type": "assertion",
        "description": "Verify the bottom save prompt bar is visible"
      },
      {
        "type": "action",
        "description": "Click the purple \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Save success\" is visible"
      }
    ]
  },
